# TaMoR production environment template
# Copy to .env.production and fill with real values. NEVER commit secrets.

ENVIRONMENT=production
DEBUG=false

DATABASE_URL=postgresql+asyncpg://tamor:CHANGE_ME@postgres:5432/tamor
REDIS_URL=redis://redis:6379/0

SECRETS_BACKEND=vault
VAULT_ADDR=https://vault.tamor.uz
VAULT_TOKEN=CHANGE_ME
VAULT_MOUNT=secret
VAULT_SECRET_PREFIX=tamor/prod

JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem

TOTP_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM_______
PINFL_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM_______
SMS_WEBHOOK_SECRET=CHANGE_ME_32_CHARS_MINIMUM_______
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_32_CHARS_MINIMUM_______

CORS_ORIGINS=["https://tamor.toyloq.uz"]
AI_ANALYTICS_URL=http://ai-analytics:8001

ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_API_TOKEN=

TELEGRAM_BOT_TOKEN=
SMTP_HOST=

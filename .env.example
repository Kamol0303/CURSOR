# TaMoR Platform Environment Configuration
# Copy to .env and adjust values for your environment

ENVIRONMENT=development
DEBUG=true

# Database — PostgreSQL (recommended) or SQLite for local dev
DATABASE_URL=postgresql+asyncpg://tamor:tamor_dev_password@localhost:5432/tamor
DATABASE_URL_SYNC=postgresql://tamor:tamor_dev_password@localhost:5432/tamor

# SQLite local dev (no PostgreSQL required):
# DATABASE_URL=sqlite+aiosqlite:///./tamor.db
# DATABASE_URL_SYNC=sqlite:///./tamor.db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (RS256) - generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY_PATH=./backend/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./backend/keys/jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption keys (32-byte base64 for Fernet)
TOTP_ENCRYPTION_KEY=change-me-to-32-byte-base64-key==
PINFL_ENCRYPTION_KEY=change-me-to-32-byte-base64-key==

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=tamor_minio
S3_SECRET_KEY=tamor_minio_secret
S3_BUCKET=tamor-files

# SMS (dev mode logs to console)
SMS_PROVIDER=console
SMS_API_KEY=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

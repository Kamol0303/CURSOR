ENVIRONMENT=development
DEBUG=true
DATABASE_URL=postgresql+asyncpg://tamor:tamor_dev@postgres:5432/tamor
REDIS_URL=redis://redis:6379/0
JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem
TOTP_ENCRYPTION_KEY=dev-only-change-in-production-32bytes!!
PINFL_ENCRYPTION_KEY=dev-pinfl-key-change-in-prod!!
CORS_ORIGINS=["http://localhost:3000"]
AI_ANALYTICS_URL=http://ai-analytics:8001

# LLM — BazaarLink (OpenAI-compatible) or direct OpenAI
# BazaarLink: https://bazaarlink.ai/api/v1  model: openai/gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=https://bazaarlink.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
AI_ENABLED=true
# Legacy fallback (used only if LLM_API_KEY is empty)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_EXAM_ENABLED=true

SECRETS_BACKEND=file
VAULT_ADDR=
VAULT_TOKEN=
VAULT_MOUNT=secret
VAULT_SECRET_PREFIX=tamor

ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_API_TOKEN=

# Click (https://docs.click.uz/)
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# Payme Merchant API (https://developer.help.paycom.uz/)
PAYME_SECRET_KEY=
PAYME_MERCHANT_LOGIN=Paycom

# Dev only — never enable in production (blocked by production validator)
PAYMENT_WEBHOOK_ALLOW_UNSIGNED_DEV=false

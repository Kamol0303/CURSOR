# TMB staging environment template
# Copy to .env.staging — NEVER commit .env.staging (gitignored).

ENVIRONMENT=staging
DEBUG=false
SECRETS_BACKEND=file

PUBLIC_HOST=tamor.staging.local

POSTGRES_USER=tamor
POSTGRES_PASSWORD=CHANGE_ME_staging_db_password
POSTGRES_DB=tamor

DATABASE_URL=postgresql+asyncpg://tamor:CHANGE_ME_staging_db_password@postgres:5432/tamor
REDIS_URL=redis://redis:6379/0

JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem

TOTP_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM_______
PINFL_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM_______
SMS_WEBHOOK_SECRET=CHANGE_ME_32_CHARS_MINIMUM_______
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_32_CHARS_MINIMUM_______

CORS_ORIGINS=["https://tamor.staging.local"]
AI_ANALYTICS_URL=http://ai-analytics:8001

LLM_API_KEY=
LLM_BASE_URL=https://bazaarlink.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
AI_ENABLED=true

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash

# SMS (eskiz.uz) — empty = stub in staging logs
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_API_TOKEN=

# Telegram bot
TELEGRAM_BOT_TOKEN=

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="TMB <noreply@example.com>"

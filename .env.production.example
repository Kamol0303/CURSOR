# TMB production environment template
# Copy to .env.production and fill with real values. NEVER commit secrets.

ENVIRONMENT=production
DEBUG=false

PUBLIC_HOST=tamor.toyloq.uz

POSTGRES_USER=tamor
POSTGRES_PASSWORD=CHANGE_ME_production_db_password
POSTGRES_DB=tamor

DATABASE_URL=postgresql+asyncpg://tamor:CHANGE_ME_production_db_password@postgres:5432/tamor
REDIS_URL=redis://redis:6379/0

# --- Secrets backend (ADR-008) ---
# Vault KV v2 path: secret/tmb/prod/jwt_private_key, jwt_public_key
SECRETS_BACKEND=vault
VAULT_ADDR=https://vault.tamor.uz
VAULT_TOKEN=CHANGE_ME_vault_token_from_ops
VAULT_MOUNT=secret
VAULT_SECRET_PREFIX=tmb/prod

JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem

# Generate: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM_______
PINFL_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM_______
SMS_WEBHOOK_SECRET=CHANGE_ME_32_CHARS_MINIMUM_______
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_32_CHARS_MINIMUM_______

CORS_ORIGINS=["https://tamor.toyloq.uz"]
AI_ANALYTICS_URL=http://ai-analytics:8001

# --- Payment gateways (production mandatory) ---
# Click: https://docs.click.uz/ — merchant cabinet → Service ID + Secret Key
CLICK_SERVICE_ID=CHANGE_ME_click_service_id
CLICK_SECRET_KEY=CHANGE_ME_click_secret_key

# Payme: https://developer.help.paycom.uz/ — Merchant API key
PAYME_SECRET_KEY=CHANGE_ME_payme_secret_key
PAYME_MERCHANT_LOGIN=Paycom

# MUST be false in production (validated by production.py)
PAYMENT_WEBHOOK_ALLOW_UNSIGNED_DEV=false

# --- SMS / notifications ---
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_API_TOKEN=

TELEGRAM_BOT_TOKEN=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="TMB <noreply@toyloq.uz>"

# --- TLS (CA-signed, NOT self-signed) ---
# Place files in infra/nginx/tls/:
#   fullchain.pem  — CA certificate chain
#   privkey.pem    — private key
# Obtain from district CA or Let's Encrypt with approved DNS.

# --- Data localization ---
# Deploy docker-compose.prod.yml on Uzbekistan-hosted VMs only.

# Local development (Git Bash, no Docker)
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://tamor:tamor_dev@localhost:5432/tamor
REDIS_URL=memory://local
USE_MEMORY_REDIS=true

JWT_PRIVATE_KEY_PATH=secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=secrets/jwt_public.pem

TOTP_ENCRYPTION_KEY=dev-only-change-in-production-32bytes!!
PINFL_ENCRYPTION_KEY=dev-pinfl-key-change-in-prod!!

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
